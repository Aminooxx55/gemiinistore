# ================================
#  Telegram Shop Bot - .env config
# ================================

# Get this from @BotFather on Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram user ID (get from @userinfobot)
ADMIN_ID=YOUR_TELEGRAM_ID_HERE

# Bot username (without @)
BOT_USERNAME=your_bot_username

# ---- Channel Membership Check ----
# Channel username (including @) that users must join
REQUIRED_CHANNEL=@grokkkmet
# Set to True to block users if they haven't joined (or if checking fails due to setup)
STRICT_CHANNEL_CHECK=True


# ---- Crypto Payment Addresses ----
USDT_POL_ADDRESS=YOUR_POL_ADDRESS
USDT_BEP20_ADDRESS=YOUR_BEP20_ADDRESS
BINANCE_PAY_ID=YOUR_BINANCE_PAY_ID

# ---- Referral Settings ----
# Amount (in USD) rewarded per successful referral
REFERRAL_REWARD=0.50

# ---- Membership Thresholds (total spent in USD) ----
SILVER_THRESHOLD=50
GOLD_THRESHOLD=200
DIAMOND_THRESHOLD=500

# ---- Recurring Message Sender ----
# Chat username (like @elitemethodchat) or Chat ID to send messages to
RECURRING_CHAT=
# The message content to send (supports HTML formatting, e.g. <b>bold</b>, <i>italic</i>, <a href="URL">link</a>)
RECURRING_MESSAGE=
# Interval in seconds (e.g. 300 for every 5 minutes)
RECURRING_INTERVAL=300

# ---- Loyalty Cashback ----
# Cashback reward percentage (e.g. 0.05 for 5%)
CASHBACK_PERCENT=0.05

# ---- Lucky Spin ----
# Cooldown between daily spins in seconds (e.g. 86400 for 24 hours)
SPIN_COOLDOWN=86400


